            if token:
                self.log(f"✅ Solver 返回 token: {token[:50]}...")
            return token
        except Exception as e:
            self.log(f"⚠️ Captcha Solver 失败: {e}")
            return None

    def run(self, email: str, password: str = "") -> dict:
